<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:show_buffering="when_playing"
        app:show_timeout="3000"
        app:use_controller="true"
        app:keep_content_on_player_reset="true"
        app:resize_mode="fill" />

    <!-- Overlay Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Top Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Kembali"
                app:tint="@color/white" />

            <!-- Episode Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dramaTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/episodeInfoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Detail Button -->
            <ImageButton
                android:id="@+id/detailButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Detail"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- Center Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Previous Episode -->
            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@drawable/circle_button_background"
                android:contentDescription="Episode Sebelumnya"
                app:tint="@color/white" />

            <!-- Play/Pause -->
            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/circle_button_background"
                android:contentDescription="Play/Pause"
                app:tint="@color/white"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp" />

            <!-- Next Episode -->
            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_media_next"
                android:background="@drawable/circle_button_background"
                android:contentDescription="Episode Berikutnya"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- Bottom Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <!-- Genre Filter Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/genreButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Genre"
                app:backgroundTint="@color/primary"
                app:tint="@color/white"
                app:fabSize="mini" />

        </LinearLayout>

    </LinearLayout>

    <!-- Genre Filter Panel -->
    <LinearLayout
        android:id="@+id/genrePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/black"
        android:visibility="gone"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filter Genre"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/genreChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp" />

    </LinearLayout>

</FrameLayout>
